<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.ui.layout.form">
    <Dialog
        title="{i18n>releaseDialogTitle}"
        contentWidth="560px"
        draggable="true"
        resizable="true"
        horizontalScrolling="false"
        stretchOnPhone="true"
        class="sapUiResponsivePadding--content sapUiResponsivePadding--header sapUiResponsivePadding--footer">
        <content>
            <VBox class="sapUiSmallMarginBottom sapUiTinyMarginTop">
                <Title text="{i18n>releaseStartConfiguration}" level="H5" class="sapUiTinyMarginBottom"/>
                <Text text="{i18n>releaseStartConfigurationDesc}" wrapping="true"/>
            </VBox>

            <IconTabBar id="idStartModeTabs" expandable="false" class="sapUiNoContentPadding sapUiTinyMarginBottom sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter key="immediate" text="{i18n>releaseQuickStart}" icon="sap-icon://play">
                        <VBox class="sapUiSmallMarginTop sapUiSmallMarginBottom sapUiSmallMarginBegin sapUiSmallMarginEnd">
                            <Text text="{i18n>releaseQuickStartDesc}" wrapping="true" class="sapUiTinyMarginBottom"/>
                            <CheckBox
                                id="idImmedCheck"
                                text="{i18n>releaseRunImmediately}"
                                tooltip="{i18n>releaseRunImmediatelyTooltip}"
                                selected="{localRelease>/isImmediate}"
                                select="onImmediateChange"/>
                            <MessageStrip
                                text="{i18n>releaseImmediateInfo}"
                                type="Success"
                                showIcon="true"
                                showCloseButton="false"
                                visible="{localRelease>/isImmediate}"
                                class="sapUiTinyMarginTop"/>
                        </VBox>
                    </IconTabFilter>

                    <IconTabFilter key="scheduled" text="{i18n>releaseScheduledStart}" icon="sap-icon://date-time" visible="{= !${localRelease>/isImmediate}}">
                        <VBox class="sapUiSmallMarginTop sapUiSmallMarginBottom sapUiSmallMarginBegin sapUiSmallMarginEnd">
                            <Text text="{i18n>releaseScheduledStartDesc}" wrapping="true" class="sapUiTinyMarginBottom"/>

                            <f:SimpleForm
                                editable="true"
                                layout="ResponsiveGridLayout"
                                class="sapUiNoMarginTop"
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                adjustLabelSpan="false"
                                emptySpanXL="1"
                                emptySpanL="1"
                                emptySpanM="0"
                                emptySpanS="0"
                                columnsXL="1"
                                columnsL="1"
                                columnsM="1">
                                <f:content>
                                    <Label text="{i18n>releaseScheduledDate}" labelFor="idReleaseDate"
                                        visible="{= !${localRelease>/isImmediate}}"
                                        required="{= !${localRelease>/isImmediate}}"/>
                                    <DatePicker
                                        id="idReleaseDate"
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="long"
                                        width="100%"
                                        placeholder="{i18n>releaseScheduledDatePlaceholder}"
                                        visible="{= !${localRelease>/isImmediate}}"/>

                                    <Label text="{i18n>releaseScheduledTime}" labelFor="idReleaseTime"
                                        visible="{= !${localRelease>/isImmediate}}"
                                        required="{= !${localRelease>/isImmediate}}"/>
                                    <TimePicker
                                        id="idReleaseTime"
                                        valueFormat="HH:mm:ss"
                                        displayFormat="medium"
                                        width="100%"
                                        placeholder="{i18n>releaseScheduledTimePlaceholder}"
                                        visible="{= !${localRelease>/isImmediate}}"/>
                                </f:content>
                            </f:SimpleForm>

                            <MessageStrip
                                text="{i18n>releaseScheduledInfo}"
                                type="Warning"
                                showIcon="true"
                                showCloseButton="false"
                                visible="{= !${localRelease>/isImmediate}}"
                                class="sapUiTinyMarginTop"/>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
        <beginButton>
            <Button text="{i18n>btnConfirmRelease}" type="Emphasized" icon="sap-icon://accept" press="onConfirmRelease"/>
        </beginButton>
        <endButton>
            <Button text="{i18n>btnCancel}" type="Transparent" press="onCloseReleaseDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
