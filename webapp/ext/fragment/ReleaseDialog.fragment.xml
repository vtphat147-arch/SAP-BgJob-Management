<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.ui.layout.form">
    <Dialog
        title="Release Job"
        contentWidth="560px"
        draggable="true"
        resizable="true"
        horizontalScrolling="false"
        stretchOnPhone="true"
        class="sapUiResponsivePadding--content sapUiResponsivePadding--header sapUiResponsivePadding--footer">
        <content>
            <VBox class="sapUiSmallMarginBottom sapUiTinyMarginTop">
                <Title text="Start Configuration" level="H5" class="sapUiTinyMarginBottom"/>
                <Text text="Choose how this job should start: run immediately or schedule an exact date and time." wrapping="true"/>
            </VBox>

            <IconTabBar id="idStartModeTabs" expandable="false" class="sapUiNoContentPadding sapUiTinyMarginBottom sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter key="immediate" text="Quick Start" icon="sap-icon://play">
                        <VBox class="sapUiSmallMarginTop sapUiSmallMarginBottom sapUiSmallMarginBegin sapUiSmallMarginEnd">
                            <Text text="Use this mode to release and start the job instantly after confirmation." wrapping="true" class="sapUiTinyMarginBottom"/>
                            <CheckBox
                                id="idImmedCheck"
                                text="Run immediately"
                                tooltip="Start the job right away"
                                selected="{localRelease>/isImmediate}"
                                select="onImmediateChange"/>
                            <MessageStrip
                                text="{= ${localRelease>/recurrence} !== 'Single Run' ? 'Job sẽ chạy ngay lập tức và lặp lại theo chu kỳ đã chọn' : 'The job will be released and started immediately after you confirm.'}"
                                type="{= ${localRelease>/recurrence} !== 'Single Run' ? 'Warning' : 'Success'}"
                                showIcon="true"
                                showCloseButton="false"
                                visible="{localRelease>/isImmediate}"
                                class="sapUiTinyMarginTop"/>
                        </VBox>
                    </IconTabFilter>

                    <IconTabFilter key="scheduled" text="Scheduled Start" icon="sap-icon://date-time" visible="{= !${localRelease>/isImmediate}}">
                        <VBox class="sapUiSmallMarginTop sapUiSmallMarginBottom sapUiSmallMarginBegin sapUiSmallMarginEnd">
                            <Text text="Disable Run immediately to set a planned start date and time." wrapping="true" class="sapUiTinyMarginBottom"/>

                            <f:SimpleForm
                                editable="true"
                                layout="ResponsiveGridLayout"
                                class="sapUiNoMarginTop"
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                adjustLabelSpan="false"
                                emptySpanXL="1"
                                emptySpanL="1"
                                emptySpanM="0"
                                emptySpanS="0"
                                columnsXL="1"
                                columnsL="1"
                                columnsM="1">
                                <f:content>
                                    <Label text="Scheduled Start (Local Time)" labelFor="idReleaseDateTime"
                                        visible="{= !${localRelease>/isImmediate}}"
                                        required="{= !${localRelease>/isImmediate}}"/>
                                    <DateTimePicker
                                        id="idReleaseDateTime"
                                        displayFormat="dd.MM.yyyy, HH:mm:ss"
                                        width="100%"
                                        placeholder="Select scheduled date and time"
                                        change=".onReleaseDateTimeChange"
                                        visible="{= !${localRelease>/isImmediate}}"/>
                                </f:content>
                            </f:SimpleForm>

                            <MessageStrip
                                text="The job will start at the scheduled date and time you selected."
                                type="Warning"
                                showIcon="true"
                                showCloseButton="false"
                                visible="{= !${localRelease>/isImmediate}}"
                                class="sapUiTinyMarginTop"/>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>

            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                class="sapUiNoMarginTop"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="1"
                emptySpanL="1"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1">
                <f:content>
                    <core:Title text="Recurrence Settings" />
                    <Label text="Recurrence Pattern" />
                    <Select selectedKey="{localRelease>/recurrence}">
                        <items>
                            <core:Item key="Single Run" text="Single Run"/>
                            <core:Item key="Minutes" text="Minutes"/>
                            <core:Item key="Hourly" text="Hourly"/>
                            <core:Item key="Daily" text="Daily"/>
                            <core:Item key="Weekly" text="Weekly"/>
                            <core:Item key="Monthly" text="Monthly"/>
                        </items>
                    </Select>

                    <Label text="Every" visible="{= ${localRelease>/recurrence} !== 'Single Run'}"/>
                    <HBox visible="{= ${localRelease>/recurrence} !== 'Single Run'}" alignItems="Center">
                        <StepInput 
                            id="idFrequencyInput"
                            value="{localRelease>/frequency}" 
                            min="1" 
                            width="6rem" 
                            change=".onFrequencyChange"
                            class="sapUiTinyMarginEnd" />
                        <Text text="{= 
                            ${localRelease>/recurrence} === 'Minutes' ? 'Minute(s)' : 
                            ${localRelease>/recurrence} === 'Hourly' ? 'Hour(s)' : 
                            ${localRelease>/recurrence} === 'Daily' ? 'Day(s)' : 
                            ${localRelease>/recurrence} === 'Weekly' ? 'Week(s)' : 'Month(s)' 
                        }"/>
                    </HBox>
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button text="Confirm Release" type="Emphasized" icon="sap-icon://accept" press="onConfirmRelease"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" type="Transparent" press="onCloseReleaseDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
