<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog title="{i18n>schedulingDialogTitle}" contentWidth="600px">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4" adjustLabelSpan="false">
                <f:content>
                    <!-- Checkbox Start Immediately -->
                    <Label text="{i18n>createJobStartImmediately}"/>
                    <CheckBox selected="{local>/startImmediately}" select=".onCheckImmediate"/>

                    <!-- Date Picker: Ẩn/Hiện dựa vào checkbox trên -->
                    <Label text="{i18n>createJobStartLocalTime}"/>
                    <DateTimePicker 
                        dateValue="{local>/startDate}" 
                        enabled="{= !${local>/startImmediately}}"
                        displayFormat="dd.MM.yyyy, HH:mm:ss"
                    />

                    <Label text="{i18n>createJobRecurrencePattern}"/>
                    <Select selectedKey="{local>/recurrence}">
                        <items>
                            <core:Item key="Single Run" text="{i18n>recurrenceSingleRun}"/>
                            <core:Item key="Minutes" text="{i18n>recurrenceMinutes}"/>
                            <core:Item key="Hourly" text="{i18n>recurrenceHourly}"/>
                            <core:Item key="Daily" text="{i18n>recurrenceDaily}"/>
                            <core:Item key="Weekly" text="{i18n>recurrenceWeekly}"/>
                            <core:Item key="Monthly" text="{i18n>recurrenceMonthly}"/>
                        </items>
                    </Select>


                    <Label text="{i18n>schedulingEvery}" visible="{= ${local>/recurrence} !== 'Single Run'}"/>
                    
                    <HBox visible="{= ${local>/recurrence} !== 'Single Run'}" alignItems="Center">
                        <Input 
                            value="{local>/frequency}" 
                            type="Number" 
                            width="4rem" 
                            maxLength="4"
                            textAlign="End"
                            class="sapUiTinyMarginEnd" />
                        
                        <Text text="{= 
                            ${local>/recurrence} === 'Minutes' ? ${i18n>schedulingMinutesUnit} : 
                            ${local>/recurrence} === 'Hourly' ? ${i18n>schedulingHourlyUnit} : 
                            ${local>/recurrence} === 'Daily' ? ${i18n>schedulingDailyUnit} : 
                            ${local>/recurrence} === 'Weekly' ? ${i18n>schedulingWeeklyUnit} : ${i18n>schedulingMonthlyUnit}
                        }"/>
                    </HBox>

                </f:content>
            </f:SimpleForm>
        </content>
        <buttons>
            <Button text="{i18n>btnOk}" type="Emphasized" press=".onCloseScheduleDialog"/>
            <Button text="{i18n>btnResetScheduling}" press=".onResetSchedule"/>
            <Button text="{i18n>btnCancel}" press=".onCancelScheduleDialog"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>