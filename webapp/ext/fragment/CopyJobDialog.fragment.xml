<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="copyJobDialog"
        title="{i18n>copyDialogTitle}"
        contentWidth="30rem"
        contentHeight="auto"
        draggable="true"
        resizable="true"
    >
        <content>
            <VBox class="sapUiSmallMargin">
                <ObjectStatus
                    title="{i18n>copyDialogSourceJob}"
                    text="{copyJob>/oldJobName}"
                    state="Information"
                    class="sapUiTinyMarginBottom"
                />
                <Label
                    text="{i18n>copyDialogNewJobName}"
                    labelFor="copyJobNameInput"
                    required="true"
                    design="Bold"
                />
                <Input
                    id="copyJobNameInput"
                    value="{copyJob>/newJobName}"
                    placeholder="{i18n>copyDialogEnterNewJobName}"
                    width="100%"
                    valueLiveUpdate="true"
                    liveChange=".onCopyJobNameLiveChange"
                    showClearIcon="true"
                    maxLength="32"
                    class="sapUiTinyMarginTop"
                />
                <Text
                    text="{i18n>copyDialogHint}"
                    class="sapUiTinyMarginTop sapUiSmallMarginBottom sapUiContentLabel"
                />
            </VBox>
        </content>
        <beginButton>
            <Button
                text="{i18n>btnCopy}"
                type="Emphasized"
                press=".onConfirmCopyJob"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>btnCancel}"
                press=".onCloseCopyDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
