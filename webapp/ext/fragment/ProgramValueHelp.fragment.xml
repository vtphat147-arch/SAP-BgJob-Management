<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        title="{i18n>programVhTitle}"
        contentWidth="800px"
        class="sapUiPopupWithPadding"
        items="{path: '/Z_I_ProgramVH', sorter: { path: 'ProgramName' }}"
        search=".onProgramSearch"
        confirm=".onProgramConfirm">
        
        <columns>
            <Column width="40%">
                <header><Text text="{i18n>createJobProgramName}" /></header>
            </Column>
            <Column width="60%">
                <header><Text text="{i18n>programVhDescription}" /></header>
            </Column>
        </columns>

        <ColumnListItem type="Active">
            <cells>
                <Text text="{ProgramName}" />
                <Text text="{Description}" />
            </cells>
        </ColumnListItem>

    </TableSelectDialog>
</core:FragmentDefinition>