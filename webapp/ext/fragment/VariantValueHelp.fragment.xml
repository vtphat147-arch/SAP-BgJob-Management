<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
     <TableSelectDialog
          title="{i18n>variantVhTitle}"
        contentWidth="600px"
        class="sapUiPopupWithPadding"
        items="{path: '/Z_I_VariantVH', sorter: { path: 'VariantName' }}"
        search=".onVariantSearch"
        confirm=".onVariantConfirm">
        
        <!-- Định nghĩa các cột -->
        <columns>
            <Column width="40%">
                <header><Text text="{i18n>createJobVariantName}" /></header>
            </Column>
            <Column width="60%">
                <header><Text text="{i18n>createdBy}" /></header>
            </Column>                           
        </columns>

        <!-- Định nghĩa dòng dữ liệu -->
        <ColumnListItem type="Active">
            <cells>
                <Text text="{VariantName}" />
                <Text text="{CreatedBy}" />
            </cells>
        </ColumnListItem>

    </TableSelectDialog>
</core:FragmentDefinition>