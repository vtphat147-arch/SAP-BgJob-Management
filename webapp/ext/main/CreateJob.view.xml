<mvc:View 
    controllerName="project5.ext.main.CreateJob" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    
    <Page id="wizardPage" title="{i18n>createJobPageTitle}" showNavButton="true" navButtonPress=".onNavBack" class="sapUiResponsiveContentPadding">
        <content>
            <Wizard id="CreateJobWizard" complete="onWizardCompleted" finishButtonText="{i18n>btnSchedule}">
                
                <WizardStep id="Step1" title="{i18n>createJobStepTemplateSelection}" validated="false" activate="onStep1Activate">
                    <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                        <f:content>
                            <Label text="{i18n>createJobJobName}" required="true"/>
                            <Input id="inpJobName" 
                                value="{local>/jobName}" 
                                liveChange=".onCheckStep1" 
                                placeholder="{i18n>createJobEnterJobNamePlaceholder}"
                                maxLength="32"
                                valueState="{= ${local>/showStep1Errors} &amp;&amp; !${local>/isJobValid} ? 'Error' : 'None' }"
                                valueStateText="{= ${local>/jobName}.length === 0 ? ${i18n>createJobPleaseEnterJobName} : ${i18n>createJobInvalidJobName} }"/>
                            
                           <Label text="{i18n>createJobProgramName}" required="true"/>
                            <Input id="inpProgram"
                                value="{local>/programName}" 
                                placeholder="{i18n>createJobEnterProgramNamePlaceholder}" 
                                showValueHelp="true" 
                                valueHelpRequest=".onProgramValueHelp"
                                change=".onProgramChange" 
                                showSuggestion="true"
                                maxLength="40"
                                suggestionItems="{/Z_I_ProgramVH}" 
                                valueState="{= ${local>/showStep1Errors} &amp;&amp; !${local>/isProgValid} ? 'Error' : 'None' }"
                                valueStateText="{= ${local>/programName}.length === 0 ? ${i18n>createJobPleaseEnterOrSelectProgramName} : ${i18n>createJobInvalidProgramName} }">

                                
                                
                                <suggestionItems>
                                    <core:ListItem text="{ProgramName}" additionalText="{Description}"/>
                                </suggestionItems>
                            </Input>
                        
                            <Label text="{i18n>createJobVariantName}" required="false"/>
                            <Input id="inpVariant" 
                                value="{local>/variantName}" 
                                placeholder="{i18n>createJobSelectVariantPlaceholder}"
                                showValueHelp="true" 
                                change=".onCheckStep1"
                                valueHelpRequest=".onVariantValueHelp"
                                valueState="None"/>
                        </f:content>
                    </f:SimpleForm>
                </WizardStep>

                <WizardStep id="Step2" title="{i18n>createJobSchedulingOptions}" validated="true"> 
                    <Toolbar>
                        <ToolbarSpacer/>
                        <Button text="{i18n>createJobDefineRecurrencePattern}" press=".onOpenScheduleDialog" type="Ghost"/>
                    </Toolbar>

                    <f:SimpleForm editable="true" layout="ResponsiveGridLayout" 
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" 
                            adjustLabelSpan="false"
                            emptySpanXL="0" emptySpanL="0" emptySpanM="0"
                            columnsXL="2" columnsL="2" columnsM="2">
                        <f:content>
                            <core:Title text="" /> 
                            <Label text="{i18n>createJobStartImmediately}"/>
                            <CheckBox selected="{local>/startImmediately}" select="onCheckImmediate"/>
                            
                            <Label text="{i18n>createJobStartLocalTime}"/>
                            <Text text="{
                                path: 'local>/startDate',
                                type: 'sap.ui.model.type.DateTime',
                                formatOptions: { style: 'medium' }
                            }" visible="{= ${local>/startImmediately}}"/>

                            <Label text="{i18n>createJobStart}"/>
                            <DateTimePicker 
                                dateValue="{local>/startDate}"
                                displayFormat="dd.MM.yyyy, HH:mm:ss"
                                enabled="{= !${local>/startImmediately}}" 
                                visible="{= !${local>/startImmediately}}"
                                valueState="{= (!${local>/startImmediately} &amp;&amp; !${local>/startDate}) ? 'Error' : 'None' }"
                                valueStateText="{i18n>createJobPleaseSelectStartDateTime}"
                            />

                            <core:Title text="" /> 
                            <Label text="{i18n>createJobRecurrencePattern}"/>
                            <Text text="{local>/recurrence}"/>
                        </f:content>
                    </f:SimpleForm>
                </WizardStep>

            </Wizard>
        </content>
        
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button text="{i18n>btnCancel}" press=".onNavBack"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>