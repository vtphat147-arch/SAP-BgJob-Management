<mvc:View
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:macros="sap.fe.macros"
    xmlns:html="http://www.w3.org/1999/xhtml"
    controllerName="project5.ext.main.Main"
>
    <f:DynamicPage
        id="Main"
        headerExpanded="true"
    >
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>MainTitle}" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <macros:FilterBar
                    id="FilterBar"
                    metaPath="/JobList/@com.sap.vocabularies.UI.v1.SelectionFields#filterBarMacro3"
                />
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <macros:Table
                id="Table"
                rowPress=".onRowPress"
                metaPath="/JobList/@com.sap.vocabularies.UI.v1.LineItem#tableMacro2"
                filterBar="FilterBar"
                header="Background Jobs"
                isSearchable="false"
                type="ResponsiveTable"
                enableFullScreen="true"
                enableExport="true"
                selectionMode="Multi"
                variantManagement="Page"
            >
                <macros:actions>
                    <Button
                        text="Refresh"
                        icon="sap-icon://refresh"
                        type="Transparent"
                        press="onRefreshTable"
                    />
                    <Button
                        id="btnManage"
                        text="Manage"
                        icon="sap-icon://action-settings"
                        type="Default"
                        press="onOpenManageMenu"
                    />
                    <Button
                        text="My Jobs"
                        icon="sap-icon://employee"
                        type="Emphasized"
                        press="onFilterOwnJobs"
                    />
                    <Button
                        text="Schedule"
                        icon="sap-icon://date-time"
                        type="Success"
                        press="onCreateJob"
                    />
                    <Button
                        id="btnAnalytics"
                        text="Quick Link"
                        icon="sap-icon://chain-link"
                        type="Transparent"
                        press="onOpenAnalyticsMenu"
                    />
                </macros:actions>
            </macros:Table>
        </f:content>
    </f:DynamicPage>
    <!-- Thêm Menu ẩn (ActionSheet) ở đây -->
    <mvc:dependents>
        <ActionSheet
            id="manageActionSheet"
            placement="Bottom"
        >
            <buttons>
                <Button
                    text="Release"
                    icon="sap-icon://unlocked"
                    press="onReleaseJob"
                />
                <Button
                    text="Repeat"
                    icon="sap-icon://synchronize"
                    press="onRepeatJob"
                />
                <Button
                    id="idCopyButton"
                    text="Copy"
                    icon="sap-icon://copy"
                    press="onCopyWithRename"
                />
                <Button
                    text="Stop"
                    icon="sap-icon://stop"
                    type="Attention"
                    press="onStopJob"
                />
                <Button
                    text="Delete"
                    icon="sap-icon://delete"
                    type="Reject"
                    press="onDeleteJob"
                />
            </buttons>
        </ActionSheet>
        <ActionSheet
            id="analyticsActionSheet"
            placement="Bottom"
        >
            <buttons>
                <Button
                    text="Dashboard"
                    icon="sap-icon://barchart"
                    press="onOpenDashboard"
                />
                <Button
                    text="Analyze"
                    icon="sap-icon://measure"
                    press="onOpenAnalytics"
                />
            </buttons>
        </ActionSheet>
    </mvc:dependents>
</mvc:View>