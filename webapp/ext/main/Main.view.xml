<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:f="sap.f" xmlns:macros="sap.fe.macros" xmlns:html="http://www.w3.org/1999/xhtml" controllerName="project5.ext.main.Main">
    <f:DynamicPage id="Main" headerExpanded="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>MainTitle}"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                 <macros:FilterBar id="FilterBar" metaPath="/JobList/@com.sap.vocabularies.UI.v1.SelectionFields#filterBarMacro3"/>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <macros:Table id="Table" rowPress=".onRowPress" metaPath="/JobList/@com.sap.vocabularies.UI.v1.LineItem#tableMacro2" filterBar="FilterBar" header="{i18n>backgroundJobs}" isSearchable="false" type="ResponsiveTable" enableFullScreen="true" enableExport="true" selectionMode="Multi" variantManagement="Page">
                <macros:actions>
                    <Button text="{i18n>btnRefresh}" icon="sap-icon://refresh" type="Transparent" press="onRefreshTable"/>
                    <Button id="btnManage" text="{i18n>btnManage}" icon="sap-icon://action" type="Default" press="onOpenManageMenu"/>
                    <Button text="{i18n>btnMyJobs}" icon="sap-icon://employee" type="Emphasized" press="onFilterOwnJobs"/>
                    <Button text="{i18n>btnSchedule}" icon="sap-icon://calendar" type="Success" press="onCreateJob"/>
                </macros:actions>
            </macros:Table>
        </f:content>
    </f:DynamicPage>

    <!-- Add hidden ActionSheet Menu here, triggered by Manage button -->
    <mvc:dependents>
        <ActionSheet id="manageActionSheet" placement="Bottom">
            <buttons>
                <Button text="{i18n>btnRelease}" icon="sap-icon://media-play" press="onReleaseJob"/>
                <Button text="{i18n>btnRepeat}" icon="sap-icon://synchronize"  press="onRepeatJob"/>
                <Button text="{i18n>btnCopy}" icon="sap-icon://copy" press="onCopyWithRename"/>
                <Button text="{i18n>btnStop}" icon="sap-icon://stop" type="Attention" press="onStopJob"/>
                <Button text="{i18n>btnDelete}" icon="sap-icon://delete" type="Reject" press="onDeleteJob"/>
            </buttons>
        </ActionSheet>
    </mvc:dependents>
</mvc:View>